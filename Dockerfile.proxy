FROM python:3.12-slim

RUN groupadd -r app && useradd -r -g app -d /app -s /sbin/nologin app

WORKDIR /app

COPY requirements-proxy.txt .
RUN pip install --no-cache-dir -r requirements-proxy.txt

COPY src/ src/
COPY config/ config/

EXPOSE 8087

HEALTHCHECK --interval=30s --timeout=5s --retries=3 \
    CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:8087/health')" || exit 1

USER app

CMD ["uvicorn", "src.services.llm_proxy:app", "--host", "0.0.0.0", "--port", "8087"]
