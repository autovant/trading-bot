# Polymarket Copy Trading Bot - Environment Variables
# Copy this to .env and fill in your values

# === Polymarket API ===
# Your wallet private key (NEVER commit this!)
POLYMARKET_PRIVATE_KEY=
# Polygon chain ID (137 for mainnet, 80001 for Mumbai testnet)
POLYMARKET_CHAIN_ID=137
# CLOB API endpoint
POLYMARKET_CLOB_URL=https://clob.polymarket.com
# Gamma API endpoint (for market data)
POLYMARKET_GAMMA_URL=https://gamma-api.polymarket.com

# === Source Wallets to Copy ===
# Comma-separated list of wallet addresses to monitor
SOURCE_WALLETS=

# === Risk Settings (override config/default.yaml) ===
# MAX_POSITION_SIZE=100.0
# MAX_PORTFOLIO_EXPOSURE=500.0
# SLIPPAGE_TOLERANCE_PCT=2.0

# === Database ===
# DATABASE_URL=sqlite:///data/trades.db

# === Logging ===
# LOG_LEVEL=INFO
