# ─── Application ───────────────────────────────────────────────
APP_MODE=paper

# ─── Database (Docker sets these automatically) ───────────────
POSTGRES_USER=tradingbot
POSTGRES_PASSWORD=CHANGE_ME_GENERATE_SECURE_PASSWORD
POSTGRES_DB=tradingbot
# For local dev without Docker:
# DATABASE_URL=sqlite:///data/trading.db

# ─── API Server ───────────────────────────────────────────────
API_KEY=CHANGE_ME_GENERATE_SECURE_TOKEN
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ─── Credential Vault ────────────────────────────────────────
# Generate with: python -c "from src.security.credential_vault import generate_master_key; print(generate_master_key())"
VAULT_MASTER_KEY=

# ─── Exchange Credentials (Required for Live/Testnet) ─────────
# Bybit
EXCHANGE_API_KEY=
EXCHANGE_SECRET_KEY=
# Zoomex (optional, for perps)
ZOOMEX_API_KEY=
ZOOMEX_API_SECRET=
ZOOMEX_BASE=https://openapi-testnet.zoomex.com

# ─── LLM Provider ────────────────────────────────────────────
# Options: github-copilot | openai-compat | gemini
LLM_PROVIDER=github-copilot
LLM_PROVIDER_URL=https://generativelanguage.googleapis.com/v1beta/openai
LLM_API_KEY=
LLM_MODEL=gemini-2.0-flash
LLM_RATE_LIMIT_RPM=30
LLM_CACHE_TTL_SECONDS=300
# Gemini fallback
GEMINI_API_KEY=

# ─── Alerts (Optional) ───────────────────────────────────────
ALERT_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=
TRADINGVIEW_WEBHOOK_SECRET=

# ─── Backup ──────────────────────────────────────────────────
BACKUP_ENCRYPTION_KEY=
